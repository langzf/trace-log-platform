PORT=3000
HOST=127.0.0.1
AUTO_ANALYZE=1
ANALYZE_INTERVAL_MS=30000
ENABLE_SQLITE_AUDIT=0
AUDIT_DB_PATH=./data/platform.db
QUEUE_MAX_ATTEMPTS=3
OPENCLAW_INSTALL_COMMAND=
OPENCLAW_INSTALL_SCRIPT=./scripts/openclaw/install_openclaw.sh
OPENCLAW_INSTALL_METHOD=auto
OPENCLAW_TARGET_VERSION=
OPENCLAW_BINARY_URL=
OPENCLAW_BINARY_SHA256=
OPENCLAW_BOOTSTRAP_URL=
OPENCLAW_INSTALL_DIR=
OPENCLAW_EXPECT_HEALTH=0
OPENCLAW_POST_INSTALL_COMMAND=
OPENCLAW_CHECK_COMMAND=openclaw --version
OPENCLAW_ENDPOINT=http://127.0.0.1:18789
OPENCLAW_HEALTH_PATH=/health
REPAIR_RECEIVER_BASE_URL=http://127.0.0.1:8788
